{
  "name": "opencode-routines-tui",
  "version": "0.1.7",
  "description": "TUI slash commands for opencode-routines: /loop, /loops, /stop-loop, and /schedule-standalone-session.",
  "main": "dist/tui.js",
  "types": "dist/tui.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "scripts": {
    "build": "mkdir -p dist && cp ../../dist/tui.js dist/tui.js && cp ../../dist/tui.d.ts dist/tui.d.ts && cp ../../LICENSE LICENSE",
    "prepublishOnly": "cd ../.. && npm test && cd packages/tui && npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tui",
    "slash-commands",
    "routines",
    "loop"
  ],
  "author": "Emilio Esposito",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EmilioEsposito/opencode-routines.git",
    "directory": "packages/tui"
  },
  "bugs": {
    "url": "https://github.com/EmilioEsposito/opencode-routines/issues"
  },
  "homepage": "https://github.com/EmilioEsposito/opencode-routines/tree/main/packages/tui#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.3"
  }
}
